# ========================================
# BOT WHATSAPP - KONFIGURASI
# ========================================

# JID Saluran/Channel WhatsApp target untuk forward audio
# Format: 123456789012345678@newsletter
# Cara mendapatkan: Jalankan bot, kirim pesan di saluran, lihat log di terminal
CHANNEL_JID=

# Nomor pemilik bot (bisa lebih dari 1, pisahkan dengan koma)
# PENTING: WhatsApp versi baru pakai format @lid (internal ID, bukan nomor HP!)
# Cek terminal saat kamu chat → cari baris [MSG-IN] from=ANGKA@lid
# Contoh 1 owner : OWNER_NUMBER=152188357705821
# Contoh 2 owner : OWNER_NUMBER=152188357705821,122372644438088
# Owner ke-2 dst bersifat hidden (tidak muncul di .menu/.help)
OWNER_NUMBER=122372644438088,152188357705821,222668972376214,86578437353665,148773925830671,249928542642268

# Nama bot
BOT_NAME=Bot Rey

# JID sumber audio yang akan di-forward (kosongkan untuk semua chat)
# Bisa diisi JID group: 123456789-123456789@g.us
# Atau JID personal: 6281234567890@s.whatsapp.net
# Kosongkan = forward audio dari SEMUA chat
FORWARD_FROM=

# Prefix perintah bot
PREFIX=.

