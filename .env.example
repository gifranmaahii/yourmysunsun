# ========================================
# BOT WHATSAPP - KONFIGURASI TEMPLATE
# ========================================
# Salin file ini menjadi .env dan isi nilainya:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/Mac)
# ========================================

# JID Saluran/Channel WhatsApp target untuk forward audio
# Format: 123456789012345678@newsletter
# Cara mendapatkan JID: jalankan bot, lalu ketik .cekjid di chat
CHANNEL_JID=

# Nomor pemilik bot (dengan kode negara, tanpa + dan tanpa spasi)
# Contoh: 6281234567890
OWNER_NUMBER=6281234567890

# Nama bot (tampil di pesan log)
BOT_NAME=Robby Bot

# JID sumber audio yang akan di-forward otomatis
# Bisa diisi JID group: 123456789-123456789@g.us
# Atau JID personal: 6281234567890@s.whatsapp.net
# Kosongkan = forward audio dari SEMUA chat
FORWARD_FROM=

# Prefix perintah bot (default: titik)
PREFIX=.

# ========================================
# REMOVE BACKGROUND (remove.bg API)
# ========================================
# Daftar GRATIS di: https://www.remove.bg/api
# Free plan: 50 kredit/bulan (1 gambar = 1 kredit)
# Dibutuhkan untuk command: .rmbg (hapus background gambar)
REMOVEBG_API_KEY=your_api_key_here

# ========================================
# INSTAGRAM DOWNLOADER
# ========================================
# Pitucode API (50 req/hari) — Daftar di: https://pitucode.com
# Auth: x-api-key header
PITUCODE_API_KEY=your_pitucode_api_key_here

# BetaBotz API (100 hit/hari) — Daftar di: https://api.betabotz.eu.org
BETABOTZ_API_KEY=your_betabotz_api_key_here

# Lolhuman API (cadangan) — Daftar di: https://api.lolhuman.xyz
LOLHUMAN_API_KEY=your_lolhuman_api_key_here
