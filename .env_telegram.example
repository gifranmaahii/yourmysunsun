# ========================================
# TELEGRAM REMOTE CONTROL - KONFIGURASI
# ========================================
# Salin file ini menjadi .env_telegram dan isi nilainya

# Token Bot Telegram (dari @BotFather)
TELEGRAM_BOT_TOKEN=

# ID Telegram Owner (dari @userinfobot atau /myid di bot ini)
# Bisa lebih dari 1, pisahkan dengan koma
# Contoh: TELEGRAM_OWNER_ID=123456789,987654321
TELEGRAM_OWNER_ID=

# ========================================
# PTERODACTYL PANEL (untuk kontrol server)
# ========================================
# Base URL panel Pterodactyl kamu
# Contoh: PTERODACTYL_BASE_URL=https://panel.example.com
PTERODACTYL_BASE_URL=

# API Key Client (dari panel: Account > API Credentials)
PTERODACTYL_API_KEY=

# Server ID (UUID pendek dari URL panel server kamu)
# Contoh: PTERODACTYL_SERVER_ID=a1b2c3d4
PTERODACTYL_SERVER_ID=
